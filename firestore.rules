rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }
    
    function uidUnchanged() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('authorUid' in request.resource.data) || request.resource.data.authorUid == resource.data.authorUid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && url.size() > 0 && url.size() <= 2000;
    }
    
    function isValidAccount(data, isCreate) {
      let validPlatforms = ['Facebook', 'YouTube'];
      let requiredFields = ['name', 'platform', 'url', 'category', 'updatedAt'];
      let createFields = ['authorUid', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             (isCreate ? data.keys().hasAll(createFields) : true) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.platform in validPlatforms &&
             isValidUrl(data.url) && data.url.size() <= 1000 &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 5000000)) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000)) &&
             (!('order' in data) || data.order is number) &&
             (!('status' in data) || data.status is string) &&
             (!('authorUid' in data) || (data.authorUid is string && data.authorUid.size() > 0)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             data.updatedAt is timestamp;
    }

    function isValidUserSettings(data) {
      return data.keys().hasAll(['authorUid', 'updatedAt']) &&
             (!('categories' in data) || (data.categories is list && data.categories.size() <= 100)) &&
             (!('newspaperCategories' in data) || (data.newspaperCategories is list && data.newspaperCategories.size() <= 100)) &&
             (!('quickKeywords' in data) || (data.quickKeywords is list && data.quickKeywords.size() <= 100)) &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.updatedAt is timestamp;
    }

    function isValidNewspaper(data, isCreate) {
      let requiredFields = ['name', 'url', 'updatedAt'];
      let createFields = ['authorUid', 'createdAt'];

      return data.keys().hasAll(requiredFields) &&
             (isCreate ? data.keys().hasAll(createFields) : true) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             isValidUrl(data.url) && data.url.size() <= 2000 &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 5000000)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 200)) &&
             (!('order' in data) || data.order is number) &&
             (!('authorUid' in data) || (data.authorUid is string && data.authorUid.size() > 0)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             data.updatedAt is timestamp;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'authorUid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /accounts/{accountId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    isValidAccount(request.resource.data, true);
      allow update: if isAuthenticated() && 
                    isValidAccount(request.resource.data, false);
      allow delete: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /userSettings/{settingId} {
      allow read: if isAuthenticated() && request.auth.uid == settingId;
      allow create: if isAuthenticated() && request.auth.uid == settingId && 
                    isValidUserSettings(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == settingId && 
                    isValidUserSettings(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == settingId;
    }

    match /newspapers/{newspaperId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    isValidNewspaper(request.resource.data, true);
      allow update: if isAuthenticated() && 
                    isValidNewspaper(request.resource.data, false);
      allow delete: if isAuthenticated();
    }

    match /newspaper_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidCategory(request.resource.data);
      allow update: if isAuthenticated() && 
                    isValidCategory(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
